rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their own data tree
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Access control settings — only authenticated users can read; only owner can write
    match /settings/accessControl {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Access requests — anyone can create (unauthenticated users requesting access)
    match /accessRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Shared project links — public read, auth write
    match /sharedProjects/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
